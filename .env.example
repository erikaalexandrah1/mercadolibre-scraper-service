# Copia este archivo a .env y ajusta los valores.
# En Coolify, define estas mismas variables en la seccion Environment Variables.

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=mercadolibre
MONGO_COLLECTION=productos

# --- Playwright / scraping ---
STORAGE_STATE_PATH=storage_state.json
HEADLESS=true
NAV_TIMEOUT_MS=30000

# --- Seguridad de la API ---
# Si defines una API_KEY, todas las rutas (menos /health) exigiran el header
# 'X-API-Key' con este valor. Dejalo vacio para una API abierta (no recomendado en prod).
API_KEY=
